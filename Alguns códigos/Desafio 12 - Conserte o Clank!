sentencas = int(input()) # Determinando o numero de sentenças a fazer.
numerodeparenteses = 0 # Determino uma váriavel numerica para utilizar como checagem de igualdade de parenteses


def checagem_parenteses(senmath, numerodeparenteses = 0):
  
  if senmath == '':  # Caso base, se meu input estiver vazio;
    return numerodeparenteses # Retorno minha variavel numerodeparenteses
  
  parentese = senmath[0] # Dou a minha variavel local, o valor do primeiro caractere do input.
  
  if parentese == ')': # Se meu primeiro caractere for ')'
    numerodeparenteses -= 1 # Diminuo um na minha contagem de igualdade.
  elif parentese == '(': # Se for ')'
    numerodeparenteses += 1 # Aumento um na contagem de igualdade.

  return checagem_parenteses(senmath[1:], numerodeparenteses) # Utilizo da recursão para continuar checando todas as letras do meu input, se for ) ou ( ele aumenta ou diminui, se não for, ele passa pro proximo.

def checar_parenteses(senmath): # Função que criei para chamar os prints e checar a situação dos mesmos.
  numero_de_parenteses = checagem_parenteses(senmath) # Tô puxando minha função dentro da minha outra função (caralho aqui o pai foi ball of gold)
  
  if numero_de_parenteses == 0: # Checo as situações dos prints
    print('Essa sentença está com os parênteses balanceados, HOORAY!')
  elif numero_de_parenteses > 0:
    print("A quantidade de parênteses '(' está maior que a de ')', vamos descartá-la")
  elif numero_de_parenteses < 0:
    print("A quantidade de parênteses ')' está maior que a de '(', vamos descartá-la")

  
  

for x in range (sentencas): # Abro meu intervalo de sentenças:
  
  senmath = input() # Input de sentenças
  checar_parenteses(senmath) # Chamada de função que vai chamar outra função.
  
