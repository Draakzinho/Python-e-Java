  listaalunos = alunos
  acao = input()
  
  
  if acao == "Daniel, mano, tô vendo um pouco do log do banco de dados. O aluno nesse índice não é o culpado. Verifica ai com o pessoal e deletem.":
    indice = int(input())
    listaalunos.pop(indice)
    print(*listaalunos, sep = ", ")
    contador_de_acoes = contador_de_acoes + 1
    dicionario[contador_de_acoes] = f"Removido aluno na posição {indice}" 
  elif acao == "Kaio, tem mais gente com 10 aqui e tinha passado batido, adiciona ai com a rapaziada:":
    alunoadd = input()
    if alunoadd not in listaalunos:
      listaalunos.append(alunoadd)
      print(f"{alunoadd} foi adicionado aos suspeitos!")
      contador_de_acoes = contador_de_acoes + 1
      dicionario[contador_de_acoes] = f"Adicionado aluno: {alunoadd}" 
    else:
      print("Breno disse que o senhor tá viajando, nenhum respeito fessor, reprova esse cara.")
  elif acao == "Cauã, vê só, acessei uma tabela aqui confiável e enfim... O último da chamada, podem descartar.":
    listaalfabetica = sorted(listaalunos)
    remover_alfabeticamente()
    contador_de_acoes = contador_de_acoes + 1
    dicionario[contador_de_acoes] = f"Removido último aluno na ordem alfabética" 
    print(*listaalfabetica, sep = ", ")
  
  elif acao == "Davi, vamo revisar o que fizemos até agora, assim a gente não se perde, beleza?":
    for k,v in dicionario.items():
      print(k,v)
  else:
    print("Marcus, perguntou se o senhor teve um derrame com a cabeça no teclado.")
  
  if len(listaalunos) == 1:
    print(f"Professor, aqui é Wollacy, quem está mentindo é: {listaalunos[0]}!")
